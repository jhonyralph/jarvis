# Generated by the toolchain on YOUR machine — not committed (large + machine-specific).
# (gitignore has no inline comments — keep patterns on their own lines.)
node_modules/
package-lock.json
# staged copy of apps/hub/web (npm run sync-web)
www/
# generated by `npx cap add android` / `npx cap add ios`
android/
ios/
# signing / secrets
*.keystore
*.jks
.env
