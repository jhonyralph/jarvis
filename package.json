{
  "name": "jarvis",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted, agent-agnostic, voice-first control plane for coding agents",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json",
    "test": "node --import tsx --test \"packages/*/src/**/*.test.ts\" \"apps/*/src/**/*.test.ts\"",
    "test:agents": "node --import tsx --test packages/core/src/agent-contract.test.ts packages/core/src/agents.test.ts packages/core/src/native.test.ts packages/core/src/turn.test.ts",
    "test:e2e": "node --import tsx --test apps/hub/src/parity.e2e.test.ts",
    "agents:report": "node --import tsx scripts/agent-report.ts",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
